{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["react", "typescript", "oxc", "import"],
  "rules": {
    "react/rules-of-hooks": "error",
    "react/only-export-components": [
      "warn",
      {
        "allowConstantExport": true
      }
    ]
  },
  "overrides": [
    {
      "files": ["src/features/queue/**"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              "**/features/analysis",
              "**/features/analysis/**",
              "**/features/history",
              "**/features/history/**",
              "**/features/statistics",
              "**/features/statistics/**",
              "**/features/settings",
              "**/features/settings/**",
              "**/dev",
              "**/dev/**"
            ]
          }
        ]
      }
    },
    {
      "files": ["src/features/analysis/**"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              "**/features/queue",
              "**/features/queue/**",
              "**/features/history",
              "**/features/history/**",
              "**/features/statistics",
              "**/features/statistics/**",
              "**/features/settings",
              "**/features/settings/**",
              "**/dev",
              "**/dev/**"
            ]
          }
        ]
      }
    },
    {
      "files": ["src/features/history/**"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              "**/features/queue",
              "**/features/queue/**",
              "**/features/analysis",
              "**/features/analysis/**",
              "**/features/statistics",
              "**/features/statistics/**",
              "**/features/settings",
              "**/features/settings/**",
              "**/dev",
              "**/dev/**"
            ]
          }
        ]
      }
    },
    {
      "files": ["src/features/statistics/**"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              "**/features/queue",
              "**/features/queue/**",
              "**/features/analysis",
              "**/features/analysis/**",
              "**/features/history",
              "**/features/history/**",
              "**/features/settings",
              "**/features/settings/**",
              "**/dev",
              "**/dev/**"
            ]
          }
        ]
      }
    },
    {
      "files": ["src/features/settings/**"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              "**/features/queue",
              "**/features/queue/**",
              "**/features/analysis",
              "**/features/analysis/**",
              "**/features/history",
              "**/features/history/**",
              "**/features/statistics",
              "**/features/statistics/**",
              "**/dev",
              "**/dev/**"
            ]
          }
        ]
      }
    },
    {
      "files": ["src/components/**", "src/lib/**"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": ["**/features", "**/features/**", "**/dev", "**/dev/**"]
          }
        ]
      }
    }
  ]
}
