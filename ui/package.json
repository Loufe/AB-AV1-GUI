{
  "name": "ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "vitest run",
    "test:node": "vitest run --project node",
    "test:browser": "vitest run --project browser",
    "typecheck": "tsc -b",
    "preview": "vite preview",
    "tauri:dev": "cd .. && tauri dev --config crates/crfty-shell/tauri.conf.json",
    "tauri:build": "cd .. && tauri build --config crates/crfty-shell/tauri.conf.json"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@dnd-kit/react": "^0.5.0",
    "@tailwindcss/vite": "^4.3.3",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.7",
    "@tauri-apps/api": "^2.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.25.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.3",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/browser-playwright": "4.1.10",
    "oxfmt": "0.59.0",
    "oxlint": "^1.71.0",
    "playwright": "1.61.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "4.1.10",
    "vitest-browser-react": "2.2.0"
  },
  "packageManager": "pnpm@11.15.0"
}
